DATABASE_URL=postgresql://feedback:feedback@postgres:5432/feedback
JWT_SECRET=change-me-in-prod-please
JWT_EXPIRE_MINUTES=1440
OPENAI_API_KEY=
# Free alternative to OpenAI (get a key at https://console.groq.com/keys). Takes
# precedence over OPENAI_API_KEY if both are set.
GROQ_API_KEY=
STORAGE_BACKEND=local
STORAGE_ROOT=/app/storage
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
# Leave both as-is for local dev (frontend/backend share "localhost"). If you deploy
# frontend and backend to different domains, set COOKIE_SAMESITE=none and
# COOKIE_SECURE=true (both together, and only over HTTPS) or login won't persist.
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
